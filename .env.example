# ===========================================
# 智能竞品分析Agent - 环境变量配置
# ===========================================

# LLM配置（MIMO - OpenAI兼容格式）
OPENAI_API_KEY=your-mimo-api-key
OPENAI_API_BASE=https://api.xiaomimimo.com/v1  # MIMO API地址
DEFAULT_MODEL=mimo-v2-omni

# Embedding配置（默认通义千问 text-embedding-v4）
# 如果用 DashScope，填你的 Aliyun API Key
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
# 不配置则回退使用 OPENAI_API_KEY 和 OPENAI_API_BASE（需支持 /embeddings 端点）

# SerpAPI配置（搜索引擎）
SERPAPI_KEY=your-serpapi-key

# Redis配置
REDIS_URL=redis://localhost:6379/0

# 数据库配置（默认使用 SQLite，生产环境建议切换 PostgreSQL）
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Chroma向量数据库配置
CHROMA_PERSIST_DIR=./data/chroma

# 报告输出配置
REPORT_OUTPUT_DIR=./data/reports

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
JWT_EXPIRE_HOURS=24

# 爬虫配置
SCRAPE_TIMEOUT=30
MAX_RETRIES=3
REQUEST_DELAY=1.0

# Apify配置（应用商店评论采集）
APIFY_API_TOKEN=your-apify-api-token

# CORS 配置（生产环境填你前端域名，多个用逗号分隔，留空则允许所有来源）
CORS_ORIGINS=

# 日志配置
LOG_LEVEL=INFO
